# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ─── Reloadly (Gift Card Verification) ──────────────────────────────────────
# Get these from: https://developers.reloadly.com → API Keys
# Set RELOADLY_ENV=sandbox for testing, production for live
RELOADLY_CLIENT_ID=YOUR_RELOADLY_CLIENT_ID
RELOADLY_CLIENT_SECRET=YOUR_RELOADLY_CLIENT_SECRET
RELOADLY_ENV=sandbox

# ─── Squad by GT (Payouts — replaces Paystack) ──────────────────────────────
# Get these from: https://dashboard.squadco.com → Settings → API Keys
# Use sandbox keys for testing: https://sandbox-api-d.squadco.com
SQUADCO_API_KEY=YOUR_SQUADCO_API_KEY
SQUADCO_SECRET_KEY=YOUR_SQUADCO_SECRET_KEY
SQUADCO_ENV=sandbox

# ─── Busha (Crypto Exchange Rates & Wallets) ────────────────────────────────
# Get this from: https://busha.co → Developer → API Keys
BUSHA_API_KEY=YOUR_BUSHA_API_KEY

# ─── Dojah (Identity Verification — BVN, NIN) ───────────────────────────────
# Get these from: https://app.dojah.io → Apps → Create App → API Keys
# Use sandbox environment for testing
DOJAH_APP_ID=YOUR_DOJAH_APP_ID
DOJAH_SECRET_KEY=YOUR_DOJAH_SECRET_KEY

# ─── App Config ─────────────────────────────────────────────────────────────
# 32+ character secret for JWT signing (generate with: openssl rand -hex 32)
APP_SECRET=GENERATE_A_32_CHARACTER_SECRET_HERE
VITE_APP_URL=http://localhost:5173
