# ─────────────────────────────────────────────────────────────────────────────
# 7SEVEN CARDS — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase (REQUIRED — app won't run without these) ───────────────────────
# Get from: https://supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# For direct DB connections (migrations, scripts):
SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_ID:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ─── Squad by GT (NGN Payouts + Premium Payments) ────────────────────────────
# Get from: https://dashboard.squadco.com → Settings → API Keys
# SQUADCO_SECRET_KEY is the "Secret Key" (Bearer token) from Squad dashboard
# Set SQUADCO_ENV=production when you go live
SQUADCO_SECRET_KEY=YOUR_SQUADCO_SECRET_KEY
SQUADCO_ENV=sandbox
# Configure Squad Webhooks in dashboard:
#   Payout webhook:  POST https://YOUR_APP_URL/api/webhooks/squadco/payout
#   Payment webhook: POST https://YOUR_APP_URL/api/webhooks/squadco/payment

# ─── Reloadly (Gift Card Verification) ───────────────────────────────────────
# Get from: https://developers.reloadly.com → API Keys
# Set RELOADLY_ENV=production for live — sandbox for testing
RELOADLY_CLIENT_ID=YOUR_RELOADLY_CLIENT_ID
RELOADLY_CLIENT_SECRET=YOUR_RELOADLY_CLIENT_SECRET
RELOADLY_ENV=sandbox

# ─── Busha (Crypto Exchange Rates) ───────────────────────────────────────────
# Get from: https://busha.co → Developer → API Keys
BUSHA_API_KEY=YOUR_BUSHA_API_KEY

# ─── Dojah (KYC — BVN & NIN Verification) ───────────────────────────────────
# Get from: https://app.dojah.io → Apps → Create App → API Keys
# App runs in demo mode (mock data) when these are missing
DOJAH_APP_ID=YOUR_DOJAH_APP_ID
DOJAH_SECRET_KEY=YOUR_DOJAH_SECRET_KEY

# ─── OneSignal (Push Notifications) ──────────────────────────────────────────
# Get from: https://app.onesignal.com → Your App → Keys & IDs
# ONESIGNAL_APP_ID      — used SERVER-SIDE to send push notifications
# VITE_ONESIGNAL_APP_ID — used CLIENT-SIDE to initialise the Web SDK
#   Both must be the same value (your OneSignal App ID).
# ONESIGNAL_ANDROID_CHANNEL_ID — Android notification channel ID (optional)
# CLIENT SETUP REQUIRED: call OneSignal.login(supabaseUserId) after sign-in
# to link the browser device to the user's Supabase UUID.
ONESIGNAL_APP_ID=YOUR_ONESIGNAL_APP_ID
VITE_ONESIGNAL_APP_ID=YOUR_ONESIGNAL_APP_ID
ONESIGNAL_REST_API_KEY=YOUR_ONESIGNAL_REST_API_KEY
ONESIGNAL_ANDROID_CHANNEL_ID=YOUR_ONESIGNAL_ANDROID_CHANNEL_ID

# ─── Telegram — Vendor Bot (Vendor Broadcast Flow) ───────────────────────────
# Create a bot via @BotFather on Telegram → /newbot → copy the API token
# TELEGRAM_BOT_TOKEN        — bot API token (server-only, never expose client-side)
# TELEGRAM_WEBHOOK_SECRET   — random 32+ char string to validate Telegram→server calls
#   Generate: openssl rand -hex 32
# Webhook is registered automatically on deploy, or manually:
#   curl -X POST "https://api.telegram.org/bot<TOKEN>/setWebhook" \
#        -d "url=https://YOUR_APP_URL/api/webhooks/telegram&secret_token=SECRET"
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_WEBHOOK_SECRET=GENERATE_A_32_CHARACTER_SECRET_HERE

# ─── Telegram — Admin Bot (Admin Approvals + Support Forwarding) ──────────────
# Create a SECOND bot via @BotFather → /newbot for admin use.
# ADMIN_TELEGRAM_BOT_TOKEN        — admin bot API token (server-only)
# ADMIN_TELEGRAM_BOT_USERNAME     — admin bot @username (without @), used for deep-links
# ADMIN_TELEGRAM_CHAT_ID          — numeric chat ID of the admin's personal chat or
#                                   a private admin group; used as a fallback for
#                                   rate-change alerts (optional — admins can also
#                                   link accounts via /start in the admin bot)
# ADMIN_TELEGRAM_WEBHOOK_SECRET   — separate 32+ char secret for the admin webhook
#   Generate: openssl rand -hex 32
# Webhook endpoint: POST /api/webhooks/telegram-admin
#   Registered automatically on deploy.
ADMIN_TELEGRAM_BOT_TOKEN=YOUR_ADMIN_TELEGRAM_BOT_TOKEN
ADMIN_TELEGRAM_BOT_USERNAME=YourAdminBotUsername
ADMIN_TELEGRAM_CHAT_ID=YOUR_ADMIN_TELEGRAM_NUMERIC_CHAT_ID
ADMIN_TELEGRAM_WEBHOOK_SECRET=GENERATE_A_DIFFERENT_32_CHARACTER_SECRET_HERE

# ─── Telegram — Support Group ────────────────────────────────────────────────
# SUPPORT_TELEGRAM_CHAT_ID — numeric chat ID of the Telegram support group.
#   The admin bot forwards user support tickets here.
#   Staff reply with: /reply <ticketId> <message>
#   Get the chat ID by adding @userinfobot to the group, or from the Telegram API.
SUPPORT_TELEGRAM_CHAT_ID=YOUR_SUPPORT_GROUP_NUMERIC_CHAT_ID

# ─── Gemini AI (OCR — Gift Card Image Scanning) ──────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Used by scanGiftCardImage() in server-functions/ocr.ts.
# Feature degrades gracefully — returns an error if missing, nothing breaks.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
# RESEND_API_KEY — used for transactional emails (receipts, KYC alerts, etc.)
# ADMIN_EMAIL    — destination for admin alerts (e.g. admin@7evencards.xyz)
# SUPPORT_EMAIL  — destination for user-facing support emails
RESEND_API_KEY=YOUR_RESEND_API_KEY
ADMIN_EMAIL=admin@7evencards.xyz
SUPPORT_EMAIL=support@7evencards.xyz

# ─── Support Contact ─────────────────────────────────────────────────────────
# SUPPORT_WHATSAPP — WhatsApp number for support (e.g. +2348012345678)
SUPPORT_WHATSAPP=+234XXXXXXXXXX

# ─── App Config ───────────────────────────────────────────────────────────────
# APP_SECRET   — 32+ character secret for JWT signing (auto-generated on first deploy)
#   Generate: openssl rand -hex 32
# CRON_SECRET  — 32+ character secret to authenticate cron-triggered HTTP calls
#   Generate: openssl rand -hex 32
#   Both are auto-generated by the deploy workflow on first deploy and saved back
#   to GitHub Secrets — you only need to set these for local dev.
APP_SECRET=GENERATE_A_32_CHARACTER_SECRET_HERE
CRON_SECRET=GENERATE_A_32_CHARACTER_SECRET_HERE
APP_URL=https://7evencards.xyz
VITE_APP_URL=http://localhost:5173
